# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environment
venv/
env/
.venv/

# Jupyter
.ipynb_checkpoints/

# All data directories — downloaded census geography, computed outputs, and
# intermediate files are not tracked. Run the pipeline to regenerate locally.
data/

# Cycle archives: binary finals/enacted_districts are too large for git.
# Only the lightweight provenance files are tracked (manifest, summaries, sources).
# Full binary archives live in GitHub Releases (see CYCLES.md).
!data/archive/
!data/archive/*/
!data/archive/*/manifest.json
!data/archive/*/data_sources.txt
!data/archive/*/summaries/
!data/archive/*/summaries/*.json

# Logs (runtime output, not source)
logs/

# macOS
.DS_Store
**/.DS_Store

# Node (used only for docx generation utility)
node_modules/
package-lock.json

# Editor
.vscode/
.idea/
*.swp
*.swo

# Misc
*.bak
nohup.out
